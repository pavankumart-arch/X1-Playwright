{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["@playwright/test", "@types/node"]
  },
  "include": [
    "**/*.ts",
    "**/*.js"
, "pages/ApplicationConfig/DomainData/Make/UpdateMakets"  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}